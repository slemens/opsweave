{
  "name": "@opsweave/backend",
  "version": "0.5.5",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp src/modules/feedback/feedback.html dist/modules/feedback/feedback.html && cp src/lib/license-public-key.pem dist/lib/license-public-key.pem",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed/index.ts"
  },
  "dependencies": {
    "@opsweave/shared": "*",
    "bcryptjs": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "i18next": "^24.0.0",
    "i18next-fs-backend": "^2.6.0",
    "imapflow": "^1.2.13",
    "jsonwebtoken": "^9.0.0",
    "mailparser": "^3.9.4",
    "morgan": "^1.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/morgan": "^1.9.0",
    "@types/pino": "^7.0.4",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
