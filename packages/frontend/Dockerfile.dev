# Build context: project root (.)
# docker-compose.dev.yml should use: context: . / dockerfile: packages/frontend/Dockerfile.dev
FROM node:22-alpine

WORKDIR /app

# Copy root workspace config
COPY package.json package-lock.json* ./

# Copy workspace package.json files
COPY packages/shared/package.json ./packages/shared/package.json
COPY packages/frontend/package.json ./packages/frontend/package.json

# Stub backend workspace
RUN mkdir -p packages/backend && \
    echo '{"name":"@opsweave/backend","version":"0.1.0","private":true}' > packages/backend/package.json

RUN npm ci --ignore-scripts

# Copy and build shared
COPY packages/shared/ ./packages/shared/
RUN npm run build -w packages/shared

# Copy frontend source (overridden by volume mounts in dev compose)
COPY packages/frontend/ ./packages/frontend/

EXPOSE 5173

CMD ["npm", "run", "dev", "-w", "packages/frontend", "--", "--host", "0.0.0.0"]
