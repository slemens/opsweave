# ═══════════════════════════════════════════════════════
# OpsWeave — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy to .env and adjust values for your deployment.
#
# IMPORTANT: In production (NODE_ENV=production), the following
# variables are MANDATORY — the app will NOT start without them:
#   - JWT_SECRET
#   - SESSION_SECRET
#   - DATABASE_URL

# ─── General ─────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────
# PostgreSQL (multi-container / docker-compose)
DB_DRIVER=pg
DATABASE_URL=postgresql://opsweave:CHANGE_THIS_PASSWORD@postgres:5432/opsweave_db

# SQLite (single-container) — uncomment to use:
# DB_DRIVER=sqlite
# DATABASE_URL=file:/data/opsweave.db

# ─── Queue ───────────────────────────────────────────
# BullMQ + Redis (multi-container)
QUEUE_DRIVER=bullmq
REDIS_URL=redis://redis:6379

# better-queue (single-container) — uncomment to use:
# QUEUE_DRIVER=better-queue

# ─── Auth (REQUIRED in production) ───────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE-ME-generate-a-random-secret
SESSION_SECRET=CHANGE-ME-generate-a-different-random-secret

# ─── OIDC (Enterprise, optional) ────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://your-domain.example.com/api/v1/auth/oidc/callback

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.example.com

# ─── i18n ────────────────────────────────────────────
DEFAULT_LANGUAGE=de

# ─── Static Files (single-container only) ────────────
SERVE_STATIC=false

# ─── PostgreSQL Container (used by docker-compose) ───
POSTGRES_USER=opsweave
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=opsweave_db
