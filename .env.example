# ═══════════════════════════════════════════════════════
# OpsWeave — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy to .env and adjust values for your deployment.

# ─── General ─────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────
# PostgreSQL (multi-container)
DB_DRIVER=pg
DATABASE_URL=postgresql://opsweave:opsweave_secret@postgres:5432/opsweave_db

# SQLite (single-container) — uncomment to use:
# DB_DRIVER=sqlite
# DATABASE_URL=file:/data/opsweave.db

# ─── Queue ───────────────────────────────────────────
# BullMQ + Redis (multi-container)
QUEUE_DRIVER=bullmq
REDIS_URL=redis://redis:6379

# better-queue (single-container) — uncomment to use:
# QUEUE_DRIVER=better-queue

# ─── Auth ────────────────────────────────────────────
SESSION_SECRET=change-me-in-production-use-a-long-random-string
JWT_SECRET=change-me-in-production-use-a-different-long-random-string

# ─── OIDC (Enterprise, optional) ────────────────────
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost/api/v1/auth/oidc/callback

# ─── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost

# ─── i18n ────────────────────────────────────────────
DEFAULT_LANGUAGE=de

# ─── Static Files (single-container only) ────────────
SERVE_STATIC=false
