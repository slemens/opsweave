# OpsWeave Configuration — copy to .env and adjust

# === Required ===
NODE_ENV=production
SESSION_SECRET=__CHANGE_ME__generate_random_32_byte_hex
JWT_SECRET=__CHANGE_ME__generate_random_32_byte_hex

# === Database ===
# Default: SQLite (single container). For production use Postgres.
DB_DRIVER=sqlite
DATA_DIR=/data
# DATABASE_URL=postgresql://opsweave:secret@postgres:5432/opsweave  # for postgres

# === License ===
# Starter Edition is free — no key needed (Limits: 50 Assets, 5 Users, 3 Workflows).
# Higher tiers: paste JWT here or activate via Settings → License.
# OPSWEAVE_LICENSE_KEY=

# === Telemetry (anonymous, opt-out) ===
# Sends instance UUID, version, DB type, aggregate counts. No PII, no business data.
OPSWEAVE_TELEMETRY=true
OPSWEAVE_UPDATE_CHECK=true

# === Locale ===
DEFAULT_LANGUAGE=de  # or 'en'
